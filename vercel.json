{
  "functions": {
    "api/[...path].ts": {
      "includeFiles": [
        "api/_lib/**",
        "src/data/**"
      ]
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
