PORT=3001

# Local development:
# Leave TURSO_DATABASE_URL empty to use a local libSQL database file at ./data/app.db
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Production / Vercel:
# Set both values below to connect to your Turso database
# TURSO_DATABASE_URL=libsql://your-database-name-your-org.turso.io
# TURSO_AUTH_TOKEN=your_turso_auth_token
